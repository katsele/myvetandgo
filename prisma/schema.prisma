// Galaxy data model — My Vet&Go
// Sections 3.1–3.5 of docs/02-architecture.md

generator client {
  provider        = "prisma-client"
  output          = "../lib/generated/prisma"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

// ─────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────

enum Profile {
  VET
  ASV
  WELLBEING
}

enum CurriculumLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum CurriculumType {
  SYSTEM
  TRANSVERSAL
  PROCEDURAL
}

enum OrgType {
  INTERNAL
  EXTERNAL
  CLINIC
  GROUP
}

enum Country {
  BE
  FR
  LU
  NL
  CH
}

enum Language {
  FR
  NL
}

enum UserRole {
  VET
  ASV
  MANAGER
  GROUP_ADMIN
  CONTRIBUTOR
  ADMIN
}

enum SubscriptionPlan {
  INDIVIDUAL_MONTHLY
  INDIVIDUAL_ANNUAL
  CLINIC_ANNUAL
  GROUP_ANNUAL
}

enum SubStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  PAUSED
}

enum ContribRole {
  PRESENTER
  REVIEWER
  QUIZ_AUTHOR
}

enum QuestionType {
  SINGLE_CHOICE
  MULTIPLE_CHOICE
}

// ─────────────────────────────────────────────
// 3.1 — Specialty & Content Hierarchy
// ─────────────────────────────────────────────

model Specialty {
  id            String       @id @default(cuid())
  slug          String       @unique
  nameFr        String
  nameNl        String
  descriptionFr String?
  descriptionNl String?
  iconUrl       String?
  wave          Int          @default(1)
  isActive      Boolean      @default(false)
  sortOrder     Int          @default(0)
  createdAt     DateTime     @default(now())

  curricula Curriculum[]
}

model Curriculum {
  id            String              @id @default(cuid())
  specialtyId   String
  nameFr        String
  nameNl        String
  descriptionFr String?
  descriptionNl String?
  profile       Profile
  type          CurriculumType
  level         CurriculumLevel     @default(BEGINNER)
  durationHours Float?
  sortOrder     Int                 @default(0)
  createdAt     DateTime            @default(now())

  specialty    Specialty              @relation(fields: [specialtyId], references: [id])
  videos       CurriculumVideo[]
  certificates SpecialtyCertificate[]
  progress     CurriculumProgress[]

  @@index([specialtyId])
}

model Video {
  id            String   @id @default(cuid())
  vimeoId       String   @unique
  titleFr       String
  titleNl       String
  descriptionFr String?
  descriptionNl String?
  durationMin   Int
  thumbnailUrl  String?
  publishedAt   DateTime?
  createdAt     DateTime @default(now())

  curriculumVideos CurriculumVideo[]
  chapters         Chapter[]
  transcripts      Transcript[]
  contributions    VideoContribution[]
  quizzes          Quiz[]
}

model CurriculumVideo {
  id           String @id @default(cuid())
  curriculumId String
  videoId      String
  sortOrder    Int    @default(0)

  curriculum Curriculum @relation(fields: [curriculumId], references: [id])
  video      Video      @relation(fields: [videoId], references: [id])

  @@unique([curriculumId, videoId])
  @@index([videoId])
}

model Chapter {
  id              String @id @default(cuid())
  videoId         String
  titleFr         String
  titleNl         String
  startTimeSec    Int
  endTimeSec      Int
  sortOrder       Int    @default(0)

  video Video @relation(fields: [videoId], references: [id])

  @@index([videoId])
}

// ─────────────────────────────────────────────
// Transcripts & Vector Search
// ─────────────────────────────────────────────

model Transcript {
  id       String   @id @default(cuid())
  videoId  String
  language Language
  vttUrl   String?
  content  String?

  video    Video              @relation(fields: [videoId], references: [id])
  segments TranscriptSegment[]

  @@unique([videoId, language])
}

model TranscriptSegment {
  id           String                          @id @default(cuid())
  transcriptId String
  startSec     Int
  endSec       Int
  text         String
  embedding    Unsupported("vector(1536)")?

  transcript Transcript @relation(fields: [transcriptId], references: [id])

  @@index([transcriptId])
}

// ─────────────────────────────────────────────
// Quiz & Assessment
// ─────────────────────────────────────────────

model Quiz {
  id           String @id @default(cuid())
  videoId      String
  titleFr      String
  titleNl      String
  passingScore Int    @default(80)
  createdAt    DateTime @default(now())

  video    Video         @relation(fields: [videoId], references: [id])
  questions Question[]
  attempts  QuizAttempt[]

  @@index([videoId])
}

model Question {
  id           String       @id @default(cuid())
  quizId       String
  questionFr   String
  questionNl   String
  questionType QuestionType @default(SINGLE_CHOICE)
  sortOrder    Int          @default(0)

  quiz    Quiz             @relation(fields: [quizId], references: [id])
  options QuestionOption[]

  @@index([quizId])
}

model QuestionOption {
  id         String  @id @default(cuid())
  questionId String
  labelFr    String
  labelNl    String
  isCorrect  Boolean @default(false)

  question Question @relation(fields: [questionId], references: [id])

  @@index([questionId])
}

model QuizAttempt {
  id              String   @id @default(cuid())
  userId          String
  quizId          String
  score           Float
  passed          Boolean
  cePointsAwarded Float    @default(0)
  completedAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  quiz Quiz  @relation(fields: [quizId], references: [id])

  @@index([userId])
  @@index([quizId])
}

// ─────────────────────────────────────────────
// Progress & Certificates
// ─────────────────────────────────────────────

model CurriculumProgress {
  id              String    @id @default(cuid())
  userId          String
  curriculumId    String
  completedVideos Int       @default(0)
  totalVideos     Int       @default(0)
  lastAccessedAt  DateTime  @default(now())
  completedAt     DateTime?

  user       User       @relation(fields: [userId], references: [id])
  curriculum Curriculum @relation(fields: [curriculumId], references: [id])

  @@unique([userId, curriculumId])
}

model SpecialtyCertificate {
  id           String   @id @default(cuid())
  userId       String
  curriculumId String
  pdfUrl       String
  issuedAt     DateTime @default(now())

  user       User       @relation(fields: [userId], references: [id])
  curriculum Curriculum @relation(fields: [curriculumId], references: [id])

  @@index([userId])
  @@index([curriculumId])
}

// ─────────────────────────────────────────────
// 3.2 — Multi-Tenant Organizations & RBAC
// ─────────────────────────────────────────────

model Organization {
  id        String   @id @default(cuid())
  name      String
  type      OrgType
  slug      String   @unique
  country   Country  @default(BE)
  parentId  String?
  maxSeats  Int?
  createdAt DateTime @default(now())

  parent       Organization?  @relation("OrgHierarchy", fields: [parentId], references: [id])
  children     Organization[] @relation("OrgHierarchy")
  subscription Subscription?
  users        User[]

  @@index([parentId])
}

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  firstName      String
  lastName       String
  language       Language  @default(FR)
  role           UserRole  @default(VET)
  orderNumber    String?
  country        Country   @default(BE)
  organizationId String
  createdAt      DateTime  @default(now())
  deactivatedAt  DateTime?

  organization   Organization           @relation(fields: [organizationId], references: [id])
  specialtyCerts SpecialtyCertificate[]
  contributor    Contributor?
  quizAttempts   QuizAttempt[]
  progress       CurriculumProgress[]

  @@index([organizationId])
}

// ─────────────────────────────────────────────
// 3.3 — Subscriptions & Billing
// ─────────────────────────────────────────────

model Subscription {
  id                String           @id @default(cuid())
  organizationId    String           @unique
  stripeCustomerId  String           @unique
  stripeSubId       String?          @unique
  plan              SubscriptionPlan
  status            SubStatus        @default(TRIALING)
  seats             Int              @default(1)
  pricePerSeat      Int
  currentPeriodEnd  DateTime
  cancelAtPeriodEnd Boolean          @default(false)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
}

// ─────────────────────────────────────────────
// 3.4 — Contributor Pipeline
// ─────────────────────────────────────────────

model Contributor {
  id          String   @id @default(cuid())
  userId      String?  @unique
  firstName   String
  lastName    String
  email       String   @unique
  title       String?
  specialties String[]
  bio         String?
  createdAt   DateTime @default(now())

  user   User?               @relation(fields: [userId], references: [id])
  videos VideoContribution[]
}

model VideoContribution {
  id            String      @id @default(cuid())
  videoId       String
  contributorId String
  role          ContribRole @default(PRESENTER)

  video       Video       @relation(fields: [videoId], references: [id])
  contributor Contributor @relation(fields: [contributorId], references: [id])

  @@index([videoId])
  @@index([contributorId])
}

// ─────────────────────────────────────────────
// 3.5 — CE Points Rules Engine
// ─────────────────────────────────────────────

model CeAccreditation {
  id              String    @id @default(cuid())
  country         Country
  bodyName        String
  accreditationId String?
  pointsPerHour   Float
  maxElearningPct Float     @default(100)
  validFrom       DateTime
  validTo         DateTime?
  createdAt       DateTime  @default(now())

  @@unique([country, bodyName])
}
